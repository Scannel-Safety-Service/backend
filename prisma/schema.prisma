datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  COMPANY_USER
}

model Company {
  id          String       @id @default(uuid())
  name        String
  archivedAt  DateTime?
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  users       User[]
  categories  Category[]
  documents   Document[]
  individuals Individual[]
  reminders   Reminder[]
  assets      Asset[]
  projects    Project[]
  folders     Folder[]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  userCode     String?   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role
  isActive     Boolean   @default(true)
  archivedAt   DateTime?
  isDeleted    Boolean   @default(false)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  refreshTokens          RefreshToken[]
  resetTokens            PasswordResetToken[]
  invitationTokens       InvitationToken[]
  impersonationsAsAdmin  ImpersonationLog[]   @relation("AdminImpersonations")
  impersonationsAsTarget ImpersonationLog[]   @relation("TargetImpersonations")
  createdCategories      Category[]           @relation("CategoryCreator")
  categoryAssignments    CategoryUser[]
  documents              Document[]
  individuals            Individual[]
  reminders              Reminder[]
  deviceTokens           DeviceToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  clientType String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model InvitationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model ImpersonationLog {
  id           String    @id @default(uuid())
  adminId      String
  admin        User      @relation("AdminImpersonations", fields: [adminId], references: [id])
  targetUserId String
  targetUser   User      @relation("TargetImpersonations", fields: [targetUserId], references: [id])
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  ipAddress    String?

  @@index([adminId])
  @@index([targetUserId])
}

enum DocumentSection {
  SAFETY_STATEMENT
  COMPANY_DOCUMENTS
  RISK_ASSESSMENT
  METHOD_STATEMENTS
  TRAINING_REGISTER
  TRAINING_QUALIFICATIONS
  ASSET_DOCUMENTS
}

model Category {
  id        String          @id @default(uuid())
  name      String
  section   DocumentSection
  companyId String?
  company   Company?        @relation(fields: [companyId], references: [id])

  assignToAll Boolean @default(false)

  createdById String
  createdBy   User   @relation("CategoryCreator", fields: [createdById], references: [id])

  assignments CategoryUser[]

  archivedAt DateTime?
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  documents  Document[]

  @@index([companyId])
  @@index([createdById])
}

model CategoryUser {
  id String @id @default(uuid())

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([categoryId, userId])
  @@index([categoryId])
  @@index([userId])
}

model Document {
  id               String          @id @default(uuid())
  title            String?
  description      String?
  isReviewed       Boolean         @default(false)
  reviewedAt       DateTime?
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  userId           String?
  user             User?           @relation(fields: [userId], references: [id])
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id])
  section          DocumentSection
  fileUrl          String
  originalFileName String
  documentType     String?
  inspectionType   String?
  archivedAt       DateTime?
  isDeleted        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([categoryId])
  @@index([assetId])
  @@index([projectId])
  @@index([folderId])
}

model StandardDocument {
  id               String    @id @default(uuid())
  title            String
  fileUrl          String
  originalFileName String
  description      String?
  archivedAt       DateTime?
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Individual {
  id         String     @id @default(uuid())
  companyId  String
  company    Company    @relation(fields: [companyId], references: [id])
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  name       String
  archivedAt DateTime?
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  reminders  Reminder[]

  @@index([companyId])
  @@index([userId])
}

model Reminder {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  individualId String?
  individual   Individual? @relation(fields: [individualId], references: [id])
  title        String
  description  String?
  dueDate      DateTime
  reminderDate DateTime?
  completedAt  DateTime?
  archivedAt   DateTime?
  isDeleted    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  notifications ReminderNotification[]

  @@index([companyId])
  @@index([userId])
  @@index([individualId])
}

// ---------------------------------------------------------------------------
// Push Notification Tracking
// ---------------------------------------------------------------------------

enum ReminderNotificationStatus {
  PENDING     // Scheduled — not yet dispatched
  PROCESSING  // Currently being dispatched (prevents double-send on concurrent ticks)
  SENT        // Successfully delivered to OneSignal
  FAILED      // Permanently failed after maxRetries attempts
  CANCELLED   // Reminder was completed/archived before dispatch
}

/// Tracks every push-notification dispatch attempt for a Reminder.
/// One record per scheduled notification event. Created automatically
/// when a Reminder is created. Retry logic updates this record in-place.
model ReminderNotification {
  id            String                     @id @default(uuid())
  reminderId    String
  reminder      Reminder                   @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  status        ReminderNotificationStatus @default(PENDING)
  scheduledAt   DateTime                   // When this notification should fire (reminderDate ?? dueDate)
  sentAt        DateTime?                  // Timestamp of successful OneSignal delivery
  lastAttemptAt DateTime?                  // Timestamp of most recent attempt (success or failure)
  nextRetryAt   DateTime?                  // Earliest time the next retry may be attempted
  retryCount    Int                        @default(0)
  maxRetries    Int                        @default(6)
  errorMessage  String?                    // Last error message — for diagnostics

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reminderId])
  // Composite index used by the scheduler query (status + scheduledAt)
  @@index([status, scheduledAt])
  @@index([status, nextRetryAt])
}

/// Stores OneSignal push subscription IDs per user.
/// One user can have multiple device tokens (multi-device support).
model DeviceToken {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String   @unique  // OneSignal push subscription ID (formerly playerId)
  deviceType     String?           // 'ios' | 'android'
  lastSeenAt     DateTime @default(now()) // Updated on every token registration

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum AssetCategory {
  PLANT
  LIFTING_EQUIPMENT
  WORKING_AT_HEIGHT
  CALIBRATION_TOOLS
}

model Asset {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name         String
  serialNumber String
  category     AssetCategory
  description  String
  expiryDate   DateTime

  archivedAt DateTime?
  isDeleted  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([expiryDate])
  @@index([category])
  @@index([projectId])
}

model Project {
  id         String     @id @default(uuid())
  companyId  String
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  year       Int
  archivedAt DateTime?
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  folders    Folder[]
  documents  Document[]
  assets     Asset[]

  @@index([companyId])
  @@index([year])
}

model Folder {
  id        String     @id @default(uuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]

  @@index([projectId])
  @@index([companyId])
}
