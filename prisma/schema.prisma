datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  COMPANY_USER
  APP_USER
}

model Company {
  id          String       @id @default(uuid())
  name        String
  isActive    Boolean      @default(true)
  archivedAt  DateTime?    // Reversible archive
  deletedAt   DateTime?    // Permanent soft-delete (hidden from UI, stays in DB)
  createdAt   DateTime     @default(now())
  users       User[]
  categories  Category[]
  documents   Document[]
  individuals Individual[]
  reminders   Reminder[]
  assets      Asset[]      // Module 3: Asset Management
  projects    Project[]
  folders     Folder[]
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  userCode        String?       // human-readable ID shown in admin UI ("User ID" in filters)
  passwordHash    String
  firstName       String
  lastName        String
  role            Role
  isActive        Boolean       @default(true)
  archivedAt      DateTime?     // Reversible archive
  deletedAt       DateTime?     // Permanent soft-delete (hidden from UI, stays in DB)

  // Tenant link — null only for SUPER_ADMIN
  companyId       String?
  company         Company?      @relation(fields: [companyId], references: [id])

  refreshTokens          RefreshToken[]
  resetTokens            PasswordResetToken[]
  invitationTokens       InvitationToken[]
  impersonationsAsAdmin  ImpersonationLog[]   @relation("AdminImpersonations")
  impersonationsAsTarget ImpersonationLog[]   @relation("TargetImpersonations")
  createdCategories      Category[]            @relation("CategoryCreator")
  categoryAssignments    CategoryUser[]
  documents              Document[]
  individuals            Individual[]
  reminders              Reminder[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([companyId])
  @@unique([companyId, userCode])   // userCode unique within a company, not globally
}

model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique   // never store raw token
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model InvitationToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model ImpersonationLog {
  id           String    @id @default(uuid())
  adminId      String
  admin        User      @relation("AdminImpersonations", fields: [adminId], references: [id])
  targetUserId String
  targetUser   User      @relation("TargetImpersonations", fields: [targetUserId], references: [id])
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  ipAddress    String?

  @@index([adminId])
  @@index([targetUserId])
}

enum DocumentSection {
  SAFETY_STATEMENT
  COMPANY_DOCUMENTS
  RISK_ASSESSMENT
  METHOD_STATEMENTS
  TRAINING_REGISTER
  TRAINING_QUALIFICATIONS
  ASSET_DOCUMENTS
}

model Category {
  id          String          @id @default(uuid())
  name        String
  section     DocumentSection
  companyId   String?
  company     Company?        @relation(fields: [companyId], references: [id])
  
  assignToAll Boolean         @default(false)
  
  createdById String
  createdBy   User            @relation("CategoryCreator", fields: [createdById], references: [id])
  
  assignments CategoryUser[]
  
  archivedAt  DateTime?       // Reversible archive
  deletedAt   DateTime?       // Permanent soft-delete (hidden from UI, stays in DB)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  documents   Document[]

  @@index([companyId])
  @@index([createdById])
}

model CategoryUser {
  id         String   @id @default(uuid())
  
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())

  @@unique([categoryId, userId]) 
  @@index([categoryId])
  @@index([userId])
}

model Document {
  id               String          @id @default(uuid())
  title            String?         // Document display title
  description      String?         // Optional document description
  isReviewed       Boolean         @default(false) // Review state
  reviewedAt       DateTime?       // Time document was reviewed
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  userId           String?
  user             User?           @relation(fields: [userId], references: [id])
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id])
  section          DocumentSection
  fileUrl          String
  originalFileName String
  documentType     String?         // e.g. INSPECTION_REPORT, SIGN_OFF, PERMIT, CERTIFICATE
  inspectionType   String?         // e.g. DAILY, WEEKLY, MONTHLY, ANNUAL, ADHOC
  archivedAt       DateTime?       // Reversible archive
  deletedAt        DateTime?       // Permanent soft-delete (hidden from UI, stays in DB)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Module 3: Asset attachment — optional FK; on asset deletion pointer is nulled (SetNull)
  assetId          String?
  asset            Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)

  // Module 4: Relational links
  projectId        String?
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folderId         String?
  folder           Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Future: Module 1 will add isLocked Boolean, signatureHash String? here

  @@index([companyId])
  @@index([userId])
  @@index([categoryId])
  @@index([assetId])
  @@index([projectId])
  @@index([folderId])
}

model StandardDocument {
  id               String    @id @default(uuid())
  title            String
  fileUrl          String
  originalFileName String
  description      String?
  archivedAt       DateTime?  // Reversible archive
  deletedAt        DateTime?  // Permanent soft-delete (hidden from UI, stays in DB)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}


model Individual {
  id         String     @id @default(uuid())
  companyId  String
  company    Company    @relation(fields: [companyId], references: [id])
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  name       String
  archivedAt DateTime?  // Reversible archive
  deletedAt  DateTime?  // Permanent soft-delete (hidden from UI, stays in DB)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  reminders  Reminder[]

  @@index([companyId])
  @@index([userId])
}

model Reminder {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  individualId String?
  individual   Individual? @relation(fields: [individualId], references: [id])
  title        String
  description  String?
  dueDate      DateTime
  reminderDate DateTime?
  completedAt  DateTime?
  archivedAt   DateTime?   // Reversible archive
  deletedAt    DateTime?   // Permanent soft-delete (hidden from UI, stays in DB)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([individualId])
}

// ---------------------------------------------------------------------------
// Module 3: Asset Management
// ---------------------------------------------------------------------------

enum AssetCategory {
  PLANT
  LIFTING_EQUIPMENT
  WORKING_AT_HEIGHT
  CALIBRATION_TOOLS
}

model Asset {
  id           String        @id @default(uuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name         String        // Human-readable label / asset name
  serialNumber String
  category     AssetCategory
  description  String
  expiryDate   DateTime      // Drives Traffic Light compliance system (Module 2)

  // Two-phase soft-delete:
  archivedAt   DateTime?     // Reversible archive
  deletedAt    DateTime?     // Permanent soft-delete (hidden from UI, stays in DB)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Related compliance certificates / inspection reports
  documents    Document[]

  // Allocated Project (optional)
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([expiryDate])         // Enables fast dashboard expiry-range queries
  @@index([category])
  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Module 4: Project Management
// ---------------------------------------------------------------------------

model Project {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  year        Int       // Used for the Year-Based Hierarchy (e.g., 2025, 2026, 2027)
  archivedAt  DateTime? // Reversible archive
  deletedAt   DateTime? // Permanent soft-delete (hidden from UI, stays in DB)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  folders     Folder[]
  documents   Document[]
  assets      Asset[]

  @@index([companyId])
  @@index([year])
}

model Folder {
  id        String     @id @default(uuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId String     // Added for automatic tenant scoping
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String     // Stores the names of the 13 standard compliance sub-folders
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]

  @@index([projectId])
  @@index([companyId])
}
