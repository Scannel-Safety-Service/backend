# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety_tracker_db?schema=public

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Application
PORT=3000
NODE_ENV=development
