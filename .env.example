# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety_tracker_db?schema=public

# JWT Configuration — Web Channel
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# JWT Configuration — Mobile Channel (activate when mobile app is live)
JWT_MOBILE_SECRET=your_separate_mobile_jwt_secret_change_me_in_production
JWT_MOBILE_ACCESS_EXPIRY=1h
JWT_MOBILE_REFRESH_EXPIRY=30d

# Application
PORT=3000
NODE_ENV=development

# Rate Limiting
THROTTLER_TTL=60000
THROTTLER_LIMIT=100
THROTTLER_AUTH_LIMIT=5

# SMTP Mail Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Global Safety Tracker <noreply@safetytracker.com>"

# OneSignal Push Notifications
# App ID: find in OneSignal Dashboard → Settings → Keys & IDs → OneSignal App ID
ONESIGNAL_APP_ID=your_onesignal_app_id_here
# REST API Key: find in OneSignal Dashboard → Settings → Keys & IDs → REST API Key
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here
